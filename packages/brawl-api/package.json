{
	"name": "@brawlbase/brawl-api",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "tsc --noEmit && tsdown --config-loader unrun",
		"test": "vitest run",
		"lint": "eslint ."
	},
	"devDependencies": {
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2"
	},
	"files": [
		"dist"
	],
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		}
	},
	"dependencies": {
		"ofetch": "^1.4.1"
	},
	"license": "MIT",
	"keywords": [
		"brawlstars",
		"brawl-stars",
		"bs",
		"api",
		"supercell",
		"brawl stars"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/technorav3nn/brawl-tracker.git",
		"directory": "packages/brawl-api"
	},
	"volta": {
		"extends": "../../package.json"
	}
}
